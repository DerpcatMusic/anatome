# Google Search Console API
# 1. Create service account: https://console.cloud.google.com/apis/credentials
# 2. Enable "Google Search Console API"
# 3. Add service account email to Search Console as Owner
# 4. Download JSON key, set path below:
GSC_KEY_FILE=/path/to/service-account-key.json
GSC_SITE_URL=https://www.anatome.co.il/

# OpenAI API
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
