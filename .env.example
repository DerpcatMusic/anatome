# Copy to .env.local for local dev (`bunx convex dev` writes most of these).
# Cloudflare Pages: set PUBLIC_CONVEX_CLIENT_URL in the dashboard (Production + Preview).

# Required for `bun run build` (public — safe to expose in the browser bundle)
# No trailing slash (avoids wss://…cloud//api/… 404s)
PUBLIC_CONVEX_CLIENT_URL=https://your-deployment.convex.cloud

# Written by Convex CLI (optional aliases — vite.config.js maps CONVEX_URL → PUBLIC_*)
# CONVEX_URL=https://your-deployment.convex.cloud
# CONVEX_SITE_URL=https://your-deployment.convex.site

# Optional (Mux player in app — leave unset to omit)
# PUBLIC_MUX_ENV_KEY=

# Web Push (PWA) — public key in browser bundle; pair with Convex VAPID_* env vars
# PUBLIC_VAPID_PUBLIC_KEY=

# Billing sandbox (local dev — optional overrides)
# Omit both: vite dev + convex dev enable subscriptions + CardCom test checkout automatically.
# PUBLIC_BILLING_SANDBOX_ENABLED=false   # force off in vite dev
# Set on Convex dev deployment: bunx convex env set BILLING_SANDBOX_ENABLED true

# CardCom (Convex deployment env — never expose to the browser)
# bunx convex env set CARDCOM_API_NAME CardTest1994
# bunx convex env set CARDCOM_TERMINAL_NUMBER 1000
# bunx convex env set CARDCOM_OPERATION ChargeOnly
# bunx convex env set FRONTEND_URL http://localhost:5173
# CONVEX_SITE_URL is written by `npx convex dev` — webhook:
#   https://<deployment>.convex.site/api/cardcom/webhook
# CARDCOM_API_PASSWORD=   # refunds only (ops via Convex Dashboard)
# HTTPS origin serving /cardcom/*.css (required for themed iframe checkout when FRONTEND_URL is localhost)
# bunx convex env set CARDCOM_CHECKOUT_CSS_URL https://anatome.co.il
# Open Fields (שדות פתוחים): ask CardCom to enable on terminal — see docs/integrations/cardcom-open-fields.md
# PUBLIC_CARDCOM_OPEN_FIELDS=true
